{
  "name": "pi-browsemode",
  "version": "0.0.1",
  "description": "pi extension that gives the agent one tool to drive a real browser via browsemode. Code mode for the web, in-sandbox element discovery, browser persists across tool calls.",
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "license": "MIT",
  "author": "michaelliv",
  "pi": {
    "extensions": [
      ".pi/extensions/browsemode"
    ]
  },
  "scripts": {
    "test": "bun test test/",
    "typecheck": "bunx tsc --noEmit"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*",
    "@sinclair/typebox": "*"
  },
  "dependencies": {
    "browsemode": "workspace:*"
  },
  "devDependencies": {
    "@mariozechner/pi-coding-agent": "^0.70.6",
    "@sinclair/typebox": "^0.34.0"
  },
  "bundledDependencies": [
    "browsemode"
  ]
}
